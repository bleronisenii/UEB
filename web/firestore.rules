rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Legacy per-user app data (uid as document id)
    match /userAppData/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    match /userAppData/{userId}/activityLog/{eventId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update, delete: if false;
    }

    // Shared org data: same paths as web/lib/firestore/userAppData.ts + activityLog.ts
    // orgs/{orgId}/userAppData/main and .../main/activityLog/{eventId}
    match /orgs/{orgId}/userAppData/{docId} {
      allow read, write: if request.auth != null;
    }
    match /orgs/{orgId}/userAppData/{docId}/activityLog/{eventId} {
      allow read, create: if request.auth != null;
      allow update, delete: if false;
    }
  }
}
