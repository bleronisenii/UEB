# Copy this file to .env.local and fill values from
# Firebase Console → Project settings → Your apps → SDK setup and configuration
#
# Vercel: Project → Settings → Environment Variables — add the same NEXT_PUBLIC_* keys
# for Production (and Preview if you want previews to work). If the Git repo root is
# not this Next app, set Vercel "Root Directory" to: web

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
